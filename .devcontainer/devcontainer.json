{
  "name": "BSFW-AstroDevContainer",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "portsAttributes": {
    "4321": {
      "label": "Application",
      "onAutoForward": "openPreview"
    }
  },
  "forwardPorts": [4321],
  "customizations": {
    "codespaces": {
      "openFiles": ["README.md", "CONTRIBUTING.md"]
    },
    "vscode": {
      "extensions": ["astro-build.astro-vscode", "esbenp.prettier-vscode"]
    }
  }
}