const dayStart = 8 * 60;
const dayEnd = 17 * 60;

const toHHMM = (minutes: number) => {
    const hour = Math.floor(minutes / 60);
    const mins = minutes % 60;
    return `${String(hour).padStart(2, '0')}${String(mins).padStart(2, '0')}`;
};

const formatTime = (value: string) => {
    const hour24 = Number.parseInt(value.slice(0, 2), 10);
    const mins = value.slice(2);
    const suffix = hour24 >= 12 ? 'PM' : 'AM';
    const hour12 = hour24 % 12 || 12;
    return `${hour12}:${mins} ${suffix}`;
};

const timeLines: string[] = [];
for (let current = dayStart; current <= dayEnd; current += 30) {
    timeLines.push(toHHMM(current));
}

const timeLabels = timeLines.filter((line) => line !== toHHMM(dayEnd));
const gridRows = ['[tracks] auto', ...timeLines.map((line) => `[time-${line}] auto`)].join(' ');
const trackOrder = new Map(tracks.map((track, index) => [track.id, index]));

const sessionsByStart = timeLabels
    .map((time) => ({
        time,
        items: sessions.filter((session) => session.start === time),
    }))
    .filter((group) => group.items.length > 0);

const getTrackLabel = (session: typeof sessions[number]) => {
    const startIndex = trackOrder.get(session.trackStart) ?? 0;
    const endIndex = trackOrder.get(session.trackEnd) ?? startIndex;

    if (startIndex === 0 && endIndex === tracks.length - 1) {
        return 'All Tracks';
    }

    if (startIndex === endIndex) {
        return tracks[startIndex].name;
    }

    return `${tracks[startIndex].name} + ${tracks[endIndex].name}`;
};

const gridPlacement = (session: typeof sessions[number]) => {
    return {
        gridRow: `time-${session.start} / time-${session.end}`,
        gridColumn: `${session.trackStart}-start / ${session.trackEnd}-end`,
    };
};
---

<Layout title="Conference Schedule - BSides Fort Wayne 2026">
    <div class="container">
        <section class="schedule-section">
            <h1>Conference Schedule</h1>
            <p class="subtitle">June 6, 2026</p>

            <div class="schedule-mobile">
                {sessionsByStart.map((group) => (
                    <section class="mobile-time-group">
                        <h3 class="mobile-time">{formatTime(group.time)}</h3>
                        <div class="mobile-session-list">
                            {group.items.map((session) => (
                                <article
                                    id={`m-${session.id}`}
                                    class={`session mobile-session ${Astro.url.hash === `#${session.id}` ? 'session-highlight' : ''}`}
                                >
                                    <h4 class="session-title">{session.title}</h4>
                                    <p class="session-meta">{formatTime(session.start)} - {formatTime(session.end)}</p>
                                    <p class="session-speaker">{session.speaker}</p>
                                    <p class="session-track-label">{getTrackLabel(session)}</p>
                                    {session.description && (
                                        <div class="session-tooltip">{session.description}</div>
                                    )}
                                </article>
                            ))}
                        </div>
                    </section>
                ))}
            </div>

            <div class="schedule-desktop" style={`--schedule-grid-rows: ${gridRows};`}>
                {tracks.map((track) => (
                    <span class="track-slot" aria-hidden="true" style={`grid-column: ${track.id};`}>
                        {track.name}
                    </span>
                ))}

                {timeLabels.map((time) => (
                    <h3 class="time-slot" style={`grid-row: time-${time};`}>
                        {formatTime(time)}
                    </h3>
                ))}

                {sessions.map((session) => (
                    <article
                        id={session.id}
                        class={`session ${Astro.url.hash === `#${session.id}` ? 'session-highlight' : ''}`}
                        style={gridPlacement(session)}
                    >
                        <h4 class="session-title">{session.title}</h4>
                        <p class="session-meta">{formatTime(session.start)} - {formatTime(session.end)}</p>
                        <p class="session-speaker">{session.speaker}</p>
                        {session.description && (
                            <div class="session-tooltip">{session.description}</div>
                        )}
                    </article>
                ))}
            </div>
        </section>
    </div>
</Layout>

<style>
    .schedule-section {
        animation: slideIn 0.5s ease-out;
    }

    h1 {
        text-align: center;
        margin-bottom: 0.5rem;
        color: #e8e8e8;
    }

    .subtitle {
        text-align: center;
        color: #268FBF;
        font-size: 1.1rem;
        margin-bottom: 2rem;
        font-weight: 500;
    }

    .schedule-mobile {
        display: grid;
        gap: 1rem;
    }

    .mobile-time-group {
        border: 1px solid #3b4654;
        border-radius: 14px;
        padding: 0.8rem;
        background: linear-gradient(180deg, #212b35 0%, #1c252f 100%);
    }

    .mobile-time {
        margin: 0 0 0.75rem;
        font-size: 0.95rem;
        font-weight: 700;
        color: #9fc4de;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .mobile-session-list {
        display: grid;
        gap: 0.75rem;
    }

    .schedule-desktop {
        display: none;
    }

    .track-slot {
        display: none;
    }

    .time-slot {
        color: #8f9fb1;
        font-size: 0.95rem;
        font-weight: 600;
        margin: 0 0 0.75rem;
        letter-spacing: 0.02em;
    }

    .session {
        background-color: #2d2d2d;
        border: 1px solid #404040;
        border-radius: 12px;
        padding: 1rem;
        margin-bottom: 1rem;
        text-align: left;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.18);
        transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
    }

    .session:hover {
        transform: translateY(-2px);
        border-color: #268FBF;
        box-shadow: 0 12px 24px rgba(38, 143, 191, 0.16);
    }

    .session-highlight {
        border-color: #268FBF;
        box-shadow: 0 0 0 2px rgba(38, 143, 191, 0.25);
    }

    .session-title {
        margin: 0 0 0.5rem;
        color: #f3f4f6;
        font-size: 1.05rem;
        line-height: 1.3;
    }

    .session-meta,
    .session-speaker {
        margin: 0;
        color: #b8c2cf;
        font-size: 0.9rem;
    }

    .session-speaker {
        margin-top: 0.35rem;
    }

    .session-track-label {
        margin: 0.5rem 0 0;
        color: #8fb6d1;
        font-size: 0.82rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .session-tooltip {
        display: none;
        margin-top: 0.75rem;
        padding: 0.75rem;
        background-color: rgba(0, 0, 0, 0.4);
        border: 1px solid #268FBF;
        border-radius: 8px;
        font-size: 0.85rem;
        line-height: 1.4;
        color: #d9e2ec;
        animation: tooltipFadeIn 0.3s ease-out;
    }

    .session:hover .session-tooltip {
        display: block;
    }

    @keyframes tooltipFadeIn {
        from {
            opacity: 0;
            transform: translateY(-8px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @supports (display: grid) {
        @media (min-width: 980px) {
            .schedule-mobile {
                display: none;
            }

            .schedule-desktop {
                display: grid;
                gap: 0.75rem;
                grid-template-rows: var(--schedule-grid-rows);
                grid-template-columns:
                    [times] 6rem
                    [track-1-start] minmax(0, 1fr)
                    [track-1-end track-2-start] minmax(0, 1fr)
                    [track-2-end track-3-start] minmax(0, 1fr)
                    [track-3-end];
                align-items: stretch;
            }

            .track-slot {
                grid-row: tracks;
                display: block;
                position: sticky;
                top: 0;
                z-index: 20;
                margin: 0;
                padding: 0.85rem 0.7rem;
                border: 1px solid #3e4956;
                border-radius: 10px;
                background: linear-gradient(160deg, #233142 0%, #1a2734 100%);
                color: #d9e2ec;
                font-size: 0.94rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.04em;
            }

            .time-slot {
                grid-column: times;
                margin: 0;
                padding-top: 0.45rem;
                text-align: right;
                font-size: 0.64rem;
                color: #88a2b8;
                border-top: 1px dashed rgba(102, 130, 154, 0.5);
                padding-right: 0.5rem;
            }

            .session {
                margin: 0;
                min-height: 84px;
            }

            .session-track-label {
                display: none;
            }
        }
    }

    @media (max-width: 768px) {
        .schedule-section {
            padding-inline: 0.2rem;
        }

        .mobile-time-group {
            padding: 0.65rem;
            border-radius: 12px;
        }

        .session {
            padding: 0.9rem;
        }

        .session-title {
            font-size: 1rem;
        }
    }
</style>
